{
  "name": "03 No-show Detection",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [ { "field": "minutes", "minutesInterval": 10 } ] } },
      "id": "triggerNoshow",
      "name": "Cada 10 min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [ 260, 300 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://bot-service:3000/internal/noshows",
        "sendHeaders": true,
        "headerParameters": { "parameters": [ { "name": "X-Internal-Token", "value": "={{$env.INTERNAL_API_SECRET}}" } ] },
        "options": {}
      },
      "id": "httpNoshow",
      "name": "POST /internal/noshows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [ 520, 300 ]
    }
  ],
  "connections": { "Cada 10 min": { "main": [ [ { "node": "POST /internal/noshows", "type": "main", "index": 0 } ] ] } }
}
